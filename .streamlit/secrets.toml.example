# Copy this file to secrets.toml (DO NOT commit the real one to GitHub)
# Fill with your actual values from Google Cloud + Google Sheet share

[gcp_service_account]
# Paste the entire downloaded JSON content from your service account key here.
# It looks like:
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "streamlit-equipment-rental@your-project.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
# universe_domain = "googleapis.com"

# Spreadsheet ID (highly recommended for security - get from your sheet URL)
SPREADSHEET_KEY = "1A2B3C4D5E6F7G8H9I0J1K2L3M4N5O6P7Q8R9S0T"   # <-- Replace with your real Sheet ID

# Optional: override config.py values if needed
# COOKIE_KEY = "your-very-long-random-string-here-at-least-64-chars"
